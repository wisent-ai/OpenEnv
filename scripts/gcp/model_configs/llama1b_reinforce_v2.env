# Llama 3.2-1B REINFORCE v2 — fixed reward function
# Changes vs v1:
#   - Adaptability: variance → coop_vs_coop * (1 - coop_vs_defect)
#   - Weights: cooperation 0.2→0.1, exploit_resist 0.2→0.3
# Goal: validate reward fix drives adaptability > 0 before spending on 7B
MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct
BATCH_SIZE=4
GRAD_ACCUM=4
LR=5e-6
MAX_STEPS=500
NUM_GEN=8
EPISODES=1000
TEMPERATURE=0.8
SAVE_STEPS=100
USE_LORA=false
QUANTIZE_4BIT=false
KL_BETA=0.05
USE_PPO=true
