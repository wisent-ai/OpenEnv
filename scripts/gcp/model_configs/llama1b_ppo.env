# Llama 3.2-1B PPO — structural fix for mode collapse
# PPO uses value head (critic) instead of group comparison
# No need for high temp/kl_beta band-aids
MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct
BATCH_SIZE=4
GRAD_ACCUM=4
LR=5e-6
MAX_STEPS=500
NUM_GEN=8
EPISODES=1000
TEMPERATURE=0.8
SAVE_STEPS=100
USE_LORA=false
QUANTIZE_4BIT=false
KL_BETA=0.05
USE_PPO=true
