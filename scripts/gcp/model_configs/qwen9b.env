# Qwen 3.5-9B — V8 pipeline (3-strategy reward, batched gen, interactive)
# LoRA + 4-bit to fit A100 40GB
# Same proven hyperparams as V8 1B, adjusted batch for memory
MODEL_NAME=Qwen/Qwen3.5-9B
BATCH_SIZE=2
GRAD_ACCUM=8
LR=2e-5
MAX_STEPS=500
NUM_GEN=8
EPISODES=1000
TEMPERATURE=1.5
SAVE_STEPS=100
USE_LORA=true
LORA_R=16
LORA_ALPHA=32
QUANTIZE_4BIT=true
KL_BETA=0.4
