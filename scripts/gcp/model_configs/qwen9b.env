# Qwen 3.5-9B — main experiment with LoRA + 4-bit (~8 hours on A100)
# Fixes from 1B run: higher temp + more generations to prevent mode collapse
MODEL_NAME=Qwen/Qwen3.5-9B
BATCH_SIZE=2
GRAD_ACCUM=8
LR=1e-5
MAX_STEPS=1000
NUM_GEN=16
EPISODES=2000
TEMPERATURE=1.1
SAVE_STEPS=50
USE_LORA=true
LORA_R=16
LORA_ALPHA=32
QUANTIZE_4BIT=true
KL_BETA=0.1
