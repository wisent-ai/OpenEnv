# Llama 3.2-1B v3 — aggressive anti-collapse
# v1: collapsed by step 100 (temp=0.8, gen=8, beta=0.04)
# v2: still collapsed by step 50 (temp=1.1, gen=16, beta=0.1)
# v3: much slower learning + heavy KL anchor + high temp
MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct
BATCH_SIZE=4
GRAD_ACCUM=4
LR=1e-6
MAX_STEPS=500
NUM_GEN=16
EPISODES=1000
TEMPERATURE=1.5
SAVE_STEPS=50
USE_LORA=false
QUANTIZE_4BIT=false
KL_BETA=0.5
