# Llama 3.2-1B v8 — fixed reward (3 strategies) + batched generation
# Key fixes from v6:
# - All 3 strategies per completion (exploit_resist+adaptability now trained)
# - Batched model.generate() (10-20x faster)
# - Equal reward weights matching eval metric
MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct
BATCH_SIZE=4
GRAD_ACCUM=4
LR=2e-5
MAX_STEPS=500
NUM_GEN=8
EPISODES=1000
TEMPERATURE=1.5
SAVE_STEPS=50
USE_LORA=false
QUANTIZE_4BIT=false
KL_BETA=0.4
