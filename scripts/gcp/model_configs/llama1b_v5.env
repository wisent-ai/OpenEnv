# Llama 3.2-1B v5 — full 5-metric reward (no hardcoded 0.5)
# Same hyperparams as v4 (best from Optuna+Hyperopt)
# Key change: reward fn now plays 3 strategies per completion
MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct
BATCH_SIZE=4
GRAD_ACCUM=4
LR=2e-5
MAX_STEPS=500
NUM_GEN=8
EPISODES=1000
TEMPERATURE=1.5
SAVE_STEPS=50
USE_LORA=false
QUANTIZE_4BIT=false
KL_BETA=0.4
