# Llama 3.2-1B v2 — anti-collapse fixes from v1 run
# Changes: temp 0.8->1.1, num_gen 8->16, kl_beta 0.04->0.1
MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct
BATCH_SIZE=4
GRAD_ACCUM=4
LR=5e-6
MAX_STEPS=500
NUM_GEN=16
EPISODES=1000
TEMPERATURE=1.1
SAVE_STEPS=50
USE_LORA=false
QUANTIZE_4BIT=false
KL_BETA=0.1
