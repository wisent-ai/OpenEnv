# Llama 3.2-1B REINFORCE v3 — full reward function fix
# Changes vs v2:
#   - exploit_resist: dead gradient fixed (now player_score_vs_defect / max_payoff)
#   - pareto: dead gradient fixed (now joint / (rounds * 6.0), gives ~0.33 for DD vs 1.0 for CC)
#   - opponent_cooperation_rate now tracked in episode results
#   - adaptability weight raised to 0.3 (strongest gradient toward TFT)
MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct
BATCH_SIZE=4
GRAD_ACCUM=4
LR=5e-6
MAX_STEPS=500
NUM_GEN=8
EPISODES=1000
TEMPERATURE=0.8
SAVE_STEPS=100
USE_LORA=false
QUANTIZE_4BIT=false
KL_BETA=0.05
USE_PPO=true
