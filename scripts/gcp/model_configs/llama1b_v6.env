# Llama 3.2-1B v6 — interactive episodes (model plays round-by-round)
# Same hyperparams as v4/v5. Key change: reward function plays
# interactive episodes where model generates actions each round,
# enabling learning of conditional strategies (tit-for-tat, etc.)
MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct
BATCH_SIZE=4
GRAD_ACCUM=4
LR=2e-5
MAX_STEPS=500
NUM_GEN=8
EPISODES=1000
TEMPERATURE=1.5
SAVE_STEPS=50
USE_LORA=false
QUANTIZE_4BIT=false
KL_BETA=0.4
