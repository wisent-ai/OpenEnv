# Qwen 2.5-7B — second scale point (non-gated, no attention bugs)
# bf16 + LoRA fits A100 40GB (~14GB model + LoRA + optimizer)
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
BATCH_SIZE=1
GRAD_ACCUM=16
LR=2e-5
MAX_STEPS=500
NUM_GEN=8
EPISODES=1000
TEMPERATURE=1.5
SAVE_STEPS=100
USE_LORA=true
LORA_R=16
LORA_ALPHA=32
QUANTIZE_4BIT=false
KL_BETA=0.4
