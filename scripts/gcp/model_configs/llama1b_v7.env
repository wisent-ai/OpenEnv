# Llama 3.2-1B v7 — longer training + pareto/fairness upweighted
# Changes from v6: 500->1000 steps, reward weights 0.15/0.25/0.25/0.20/0.15
# V6 results: exploit_resist+adaptability improved, pareto+fairness lagged
MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct
BATCH_SIZE=4
GRAD_ACCUM=4
LR=2e-5
MAX_STEPS=1000
NUM_GEN=8
EPISODES=1000
TEMPERATURE=1.5
SAVE_STEPS=100
USE_LORA=false
QUANTIZE_4BIT=false
KL_BETA=0.4
