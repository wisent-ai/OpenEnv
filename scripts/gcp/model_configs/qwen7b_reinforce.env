# Qwen 2.5-7B REINFORCE — fixed reward function, real scale experiment
# Uses same model as the GRPO 7B run for direct comparison
# bf16 + LoRA fits A100 40GB; USE_PPO=true → train.ppo_train (REINFORCE)
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
BATCH_SIZE=1
GRAD_ACCUM=16
LR=5e-6
MAX_STEPS=500
NUM_GEN=8
EPISODES=1000
TEMPERATURE=0.8
SAVE_STEPS=100
USE_LORA=true
LORA_R=16
LORA_ALPHA=32
QUANTIZE_4BIT=false
KL_BETA=0.05
USE_PPO=true
